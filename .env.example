SECRET_KEY=replace-this-with-a-real-secret-key
DEBUG=True
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Image conversion before upload (applies in all environments)
IMAGE_UPLOAD_FORMAT=webp   # webp | avif
IMAGE_UPLOAD_QUALITY=80

# Media storage (production) — Cloudflare R2. Leave blank to use local /media.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=          # public host serving the bucket, no scheme: media.example.com or pub-xxxx.r2.dev
# R2_ENDPOINT_URL=         # optional; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
