# ===========================================================================
#  PRODUCTION (cPanel) — fill in and keep active.
#  For local work, comment the four PRODUCTION lines and uncomment DEVELOPMENT.
# ===========================================================================
SECRET_KEY=replace-this-with-a-real-secret-key

DEBUG=False
# cPanel MySQL (MariaDB): db + user are prefixed with your cPanel username,
# host is local. ?charset=utf8mb4 enables full Unicode incl. emoji.
DATABASE_URL=mysql://cpaneluser_dbuser:DB_PASSWORD@localhost:3306/cpaneluser_dbname?charset=utf8mb4
ALLOWED_HOSTS=.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Image conversion before upload
IMAGE_UPLOAD_FORMAT=webp   # webp | avif
IMAGE_UPLOAD_QUALITY=80

# Cloudflare R2 media storage (used when DEBUG=False)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=          # custom domain or pub-xxxx.r2.dev (host or full URL)
# R2_ENDPOINT_URL=         # optional; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ===========================================================================
#  DEVELOPMENT (local) — uncomment and comment the PRODUCTION lines above.
# ===========================================================================
# DEBUG=True
# DATABASE_URL=sqlite:///db.sqlite3
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000
